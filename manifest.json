{
  "manifest_version": 3,
  "name": "CSS Injector",
  "version": "1.0",
  "description": "Thêm CSS tùy chỉnh vào website.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "host_permissions": [
    "*://*/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "CSS Injector"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/storage.js", "content/content.js"],
      "run_at": "document_start"
    }
  ]
}
